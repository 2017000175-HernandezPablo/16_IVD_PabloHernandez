//Verificar si un es positivo
//negativo
Algoritmo NumPosNeg
	//Entradas
	Escribir "===NUMEROS NEGATIVOS Y POSITIVOS==="
	Definir num Como Entero
	Escribir "Dame un numero entero: "
	Leer num
	
	//Proceso 
	//salida
	Si num>=0 Entonces
		Escribir "Es un numero positivo"
	SiNo
		Escribir "Es un numero negativo"
	Fin Si
FinAlgoritmo
